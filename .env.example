# 阿里云百炼平台配置（推荐）
ALIYUN_API_KEY=your_aliyun_api_key_here
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL=qwen-plus

# DeepSeek API 配置（备选）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API 配置（备选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# LLM 提供商选择：aliyun 或 deepseek 或 openai
LLM_PROVIDER=aliyun

# Embedding 模型配置（用于向量检索和分类）
# 支持 text-embedding-v1~v4 模型
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3

# ChromaDB 持久化目录
CHROMA_PERSIST_DIR=./chroma_data

# 情感分析模型
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
# SENTIMENT_FALLBACK_ENABLED: 
#   - True: 先尝试加载模型，失败后回退到关键词方案
#   - False: 直接使用关键词方案，跳过模型加载（快速启动，默认）
SENTIMENT_FALLBACK_ENABLED=False

# Hugging Face 镜像源（清华镜像，用于国内下载）
HF_ENDPOINT=https://hf-mirror.com

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 默认用户 ID
DEFAULT_USER_ID=default_user

# MCP 工具配置（用于接入外部应用）
# MCP_ENABLED: 是否启用 MCP 工具（true/false）
# MCP_SANDBOX_URL: 代码执行沙箱服务地址
# MCP_LEETCODE_URL: LeetCode 服务地址
# MCP_GITHUB_URL: GitHub 服务地址
MCP_ENABLED=false
MCP_SANDBOX_URL=http://localhost:3000
MCP_LEETCODE_URL=http://localhost:3001
MCP_GITHUB_URL=http://localhost:3002

# CareerAgent MCP 配置（用于求职辅导）
# CAREER_MCP_ENABLED: 是否启用 CareerAgent MCP 工具（true/false）
# CAREER_MCP_JOB_URL: 招聘信息服务地址
# CAREER_MCP_RESUME_URL: 简历优化服务地址
# CAREER_MCP_INTERVIEW_URL: 面试经验服务地址
CAREER_MCP_ENABLED=false
CAREER_MCP_JOB_URL=http://localhost:3003
CAREER_MCP_RESUME_URL=http://localhost:3004
CAREER_MCP_INTERVIEW_URL=http://localhost:3005